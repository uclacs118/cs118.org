---
import Assignment from './Assignment.astro';
import type { MarkdownInstance } from 'astro';
interface Frontmatter {
    title: string;
}

const problemSetSols = Object.values(import.meta.glob<MarkdownInstance<Frontmatter>>("../pages/exams/sols*.mdx", { eager: true }));
---

{problemSetSols.map(p => <Assignment title={p.frontmatter.title!} link={p.url!} dueDate={null} />)}
{problemSetSols.length == 0 ? <p>No practice problem solutions are available yet—check back later!</p> : null}
