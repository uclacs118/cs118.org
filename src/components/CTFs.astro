---
import Assignment from './Assignment.astro';
import type { MarkdownInstance } from 'astro';
interface Frontmatter {
    title: string;
}

const ctfs = Object.values(import.meta.glob<MarkdownInstance<Frontmatter>>("../pages/ctfs/ctf*.mdx", { eager: true }));
---

{ctfs.map(ctf => <Assignment title={ctf.frontmatter.title!} link={ctf.url!} dueDate={null} />)}
{ctfs.length == 0 ? <p>No CTF challenges are available yet—check back later!</p> : null}
